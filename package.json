{
  "name": "msds-management-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx server/scripts/seed.ts",
    "backfill:mvp": "tsx server/scripts/backfillMvpReview.ts",
    "reextract:components": "tsx server/scripts/reextractComponents.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "@vitejs/plugin-react": "^5.1.1",
    "better-sqlite3": "^12.5.0",
    "concurrently": "^9.2.1",
    "csv-parse": "^6.1.0",
    "express": "^5.2.1",
    "lucide-react": "^0.562.0",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.296",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tesseract.js": "^6.0.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
