# Priority 1 for MVP: 한국환경공단_화학물질 정보 조회 서비스
# https://www.data.go.kr/data/15149420/openapi.do
KECO_CHEM_API_URL=
KECO_API_SERVICE_KEY=

# Optional later/manual source: 한국산업안전보건공단_물질안전보건자료 조회 서비스
# https://www.data.go.kr/data/15157612/openapi.do
KOSHA_MSDS_API_URL=
KOSHA_API_SERVICE_KEY=

# MVP AI structuring. Keep false unless local Codex CLI use is approved.
MSDS_CODEX_ENABLED=false
MSDS_CODEX_COMMAND=codex
MSDS_CODEX_TIMEOUT_MS=60000

# Vercel frontend -> Mac mini/API server.
# Set this in Vercel Project Settings. Example: https://msds-api.company.example
VITE_API_BASE_URL=

# Mac mini/API server CORS allowlist.
# Set this on the backend host. Example: https://msds-app.vercel.app,https://msds-app-git-main-user.vercel.app
MSDS_ALLOWED_ORIGINS=http://localhost:5173
