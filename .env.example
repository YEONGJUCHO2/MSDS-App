# Priority 1 for MVP: 한국환경공단_화학물질 정보 조회 서비스
# https://www.data.go.kr/data/15149420/openapi.do
KECO_CHEM_API_URL=
KECO_API_SERVICE_KEY=

# Optional later/manual source: 한국산업안전보건공단_물질안전보건자료 조회 서비스
# https://www.data.go.kr/data/15157612/openapi.do
KOSHA_MSDS_API_URL=
KOSHA_API_SERVICE_KEY=

# MVP AI structuring. Production default is OpenAI gpt-5-mini.
MSDS_AI_PROVIDER=openai
MSDS_AI_MODEL=gpt-5-mini
MSDS_AI_TIMEOUT_MS=60000
MSDS_AI_DAILY_REQUEST_LIMIT=50
MSDS_AI_MAX_PROMPT_CHARS=20000
MSDS_AI_MAX_OUTPUT_TOKENS=3000
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Development fallback. Keep false unless local Codex CLI use is approved.
MSDS_CODEX_ENABLED=false
MSDS_CODEX_COMMAND=codex
MSDS_CODEX_TIMEOUT_MS=60000

# Local development override for external API servers.
VITE_API_BASE_URL=

# Local Express CORS allowlist.
MSDS_ALLOWED_ORIGINS=http://localhost:5173
